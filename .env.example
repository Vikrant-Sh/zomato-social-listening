# ============================================================
# Copy this file to a new file named exactly:  .env
# Then replace every dummy value with your REAL keys.
# The real .env is NEVER committed to git (.gitignore blocks it).
# ============================================================

# --- Reddit ---
# We use Reddit's public JSON endpoints (no API keys needed).
# Only a polite, descriptive user agent is required:
REDDIT_USER_AGENT=social-watch (personal assignment demo) by u/your_reddit_username

# --- Anthropic / Claude (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Slack (Incoming Webhook URL for your channel) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- ClickUp (Settings -> Apps -> API Token, and the List ID) ---
CLICKUP_API_TOKEN=pk_your_clickup_token_here
CLICKUP_LIST_ID=your_list_id_here
